NODE_ENV=production
PORT=4000

# NeonDB EU Frankfurt pooled URL
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&connection_limit=5&pool_timeout=0

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Frontend — Vercel production URL
FRONTEND_URL=https://propflow.vercel.app

# Email via Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cloudinary (EU region)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@propflow.dev

# Error monitoring
SENTRY_DSN=
