generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  LANDLORD
  TENANT
}

enum TicketCategory {
  PLUMBING
  HEATING
  INTERNET
  CLEANING
  NOISE
  ELECTRICITY
  OTHER
}

enum TicketPriority {
  URGENT
  NORMAL
  LOW
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  FIXED
  CLOSED
}

enum EmergencyType {
  WATER_LEAKAGE
  HEATING_FAILURE
  ELECTRICAL_HAZARD
  SECURITY_ISSUE
  OTHER
}

enum MessageType {
  USER_MESSAGE
  SYSTEM_MESSAGE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum VisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum VisitReason {
  ROUTINE_INSPECTION
  METER_READING
  MAINTENANCE_CHECK
  VIEWING
  OTHER
}

enum LeaseType {
  UNLIMITED
  FIXED_TERM
}

enum LeaseStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TERMINATED
}

enum DocumentCategory {
  LEASE_CONTRACT
  FLOOR_PLAN
  ENERGY_CERTIFICATE
  HOUSE_RULES
  HANDOVER_REPORT
  UTILITY_BILL
  INSPECTION_REPORT
  INSURANCE
  INVOICE
  CORRESPONDENCE
  OTHER
}

enum DocumentVisibility {
  LANDLORD_ONLY
  SHARED_WITH_TENANT
}

model Organisation {
  id             String          @id @default(uuid())
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          User[]
  properties     Property[]
  tickets        Ticket[]
  landlordVisits LandlordVisit[]
  leases         Lease[]
  documents      Document[]

  @@map("organisations")
}

model User {
  id            String       @id @default(uuid())
  orgId         String       @map("org_id")
  org           Organisation @relation(fields: [orgId], references: [id])
  role          Role         @default(TENANT)
  name          String
  email         String       @unique
  password      String
  phone         String?
  language      String       @default("de")
  isActive      Boolean      @default(true) @map("is_active")
  emailVerified Boolean      @default(false) @map("email_verified")
  refreshToken         String?   @map("refresh_token")
  pushSubscription     String?   @map("push_subscription")
  passwordResetCode    String?   @map("password_reset_code")
  passwordResetExpiry  DateTime? @map("password_reset_expiry")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  unit                  Unit?                  @relation("UnitTenant")
  tickets               Ticket[]               @relation("TicketTenant")
  ticketNotes           TicketNote[]           @relation("TicketNoteAuthor")
  sentMessages          Message[]              @relation("MessageSender")
  messageReads          MessageRead[]          @relation("MessageReader")
  createdAppointments   Appointment[]          @relation("AppointmentCreator")
  inAppNotifications    InAppNotification[]
  createdVisits         LandlordVisit[]        @relation("VisitCreator")
  visitNotifications    LandlordVisitUnit[]    @relation("VisitNotifiedTenant")
  leases                Lease[]                @relation("TenantLease")
  uploadedDocuments     Document[]             @relation("DocumentUploader")
  tenantDocuments       Document[]             @relation("DocumentTenant")
  documentAccessLogs    DocumentAccessLog[]    @relation("DocumentAccessor")

  @@index([orgId])
  @@index([email])
  @@map("users")
}

model Property {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  org         Organisation @relation(fields: [orgId], references: [id])
  name        String
  street      String
  city        String
  postalCode  String    @map("postal_code")
  country     String    @default("Germany")
  notes          String?
  latitude       Float?
  longitude      Float?
  geocodedAt     DateTime?       @map("geocoded_at")
  units          Unit[]
  landlordVisits LandlordVisit[]
  documents      Document[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("properties")
}

model Unit {
  id           String    @id @default(uuid())
  orgId        String    @map("org_id")
  propertyId   String    @map("property_id")
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitNumber   String    @map("unit_number")
  floor        Int?
  bedrooms     Int?
  sizeM2       Float?    @map("size_m2")
  tenantId     String?   @unique @map("tenant_id")
  tenant       User?     @relation("UnitTenant", fields: [tenantId], references: [id])
  notes        String?
  tickets      Ticket[]
  visitUnits   LandlordVisitUnit[]
  lease        Lease?
  documents    Document[]
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([propertyId])
  @@map("units")
}

model TenantInvite {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  unitId     String    @map("unit_id")
  email      String
  name       String
  token      String    @unique
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([orgId])
  @@map("tenant_invites")
}

model Ticket {
  id            String         @id @default(uuid())
  ticketNumber  String         @unique @map("ticket_number")
  orgId         String         @map("org_id")
  org           Organisation   @relation(fields: [orgId], references: [id])
  unitId        String         @map("unit_id")
  unit          Unit           @relation(fields: [unitId], references: [id])
  tenantId      String         @map("tenant_id")
  tenant        User           @relation("TicketTenant", fields: [tenantId], references: [id])
  category      TicketCategory
  priority      TicketPriority
  status        TicketStatus   @default(OPEN)
  title         String
  description   String
  photos        String[]
  isEmergency   Boolean        @default(false) @map("is_emergency")
  emergencyType EmergencyType? @map("emergency_type")
  closedAt      DateTime?      @map("closed_at")
  lastActivity  DateTime       @default(now()) @map("last_activity")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  statusHistory TicketStatusLog[]
  notes         TicketNote[]
  messages      Message[]
  appointments  Appointment[]

  @@index([orgId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@map("tickets")
}

model TicketStatusLog {
  id         String        @id @default(uuid())
  ticketId   String        @map("ticket_id")
  ticket     Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromStatus TicketStatus? @map("from_status")
  toStatus   TicketStatus  @map("to_status")
  changedBy  String        @map("changed_by")
  changedAt  DateTime      @default(now()) @map("changed_at")

  @@index([ticketId])
  @@map("ticket_status_logs")
}

model TicketNote {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation("TicketNoteAuthor", fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("ticket_notes")
}

model TicketCounter {
  year  Int @id
  count Int @default(0)

  @@map("ticket_counters")
}

model NotificationQueue {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  targetUserId String   @map("target_user_id")
  type         String
  channels     String[]
  payload      Json
  status       String   @default("PENDING")
  attempts     Int      @default(0)
  scheduledAt  DateTime @default(now()) @map("scheduled_at")
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([status, scheduledAt])
  @@index([orgId])
  @@map("notification_queue")
}

model Message {
  id         String      @id @default(uuid())
  orgId      String      @map("org_id")
  ticketId   String      @map("ticket_id")
  ticket     Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String?     @map("sender_id")
  sender     User?       @relation("MessageSender", fields: [senderId], references: [id])
  type       MessageType @default(USER_MESSAGE)
  content    String      @db.Text
  photo      String?
  systemKey  String?     @map("system_key")
  systemData Json?       @map("system_data")
  createdAt  DateTime    @default(now()) @map("created_at")

  reads      MessageRead[]

  @@index([ticketId, createdAt])
  @@index([orgId])
  @@map("messages")
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("MessageReader", fields: [userId], references: [id])
  readAt    DateTime @default(now()) @map("read_at")

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_reads")
}

model Appointment {
  id           String            @id @default(uuid())
  orgId        String            @map("org_id")
  ticketId     String            @map("ticket_id")
  ticket       Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdById  String            @map("created_by_id")
  createdBy    User              @relation("AppointmentCreator", fields: [createdById], references: [id])
  scheduledAt  DateTime          @map("scheduled_at")
  durationMin  Int               @default(60) @map("duration_min")
  note         String?
  status       AppointmentStatus @default(SCHEDULED)
  cancelReason String?           @map("cancel_reason")
  completedAt  DateTime?         @map("completed_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([ticketId])
  @@index([scheduledAt])
  @@map("appointments")
}

model InAppNotification {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([orgId])
  @@map("in_app_notifications")
}

model LandlordVisit {
  id           String        @id @default(uuid())
  orgId        String        @map("org_id")
  org          Organisation  @relation(fields: [orgId], references: [id])
  propertyId   String        @map("property_id")
  property     Property      @relation(fields: [propertyId], references: [id])
  createdById  String        @map("created_by_id")
  createdBy    User          @relation("VisitCreator", fields: [createdById], references: [id])
  scheduledAt  DateTime      @map("scheduled_at")
  durationMin  Int           @default(60) @map("duration_min")
  reason       VisitReason   @default(OTHER)
  note         String?       @db.Text
  status       VisitStatus   @default(SCHEDULED)
  cancelReason String?       @map("cancel_reason")
  completedAt  DateTime?     @map("completed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  units        LandlordVisitUnit[]

  @@index([orgId])
  @@index([propertyId])
  @@index([scheduledAt])
  @@map("landlord_visits")
}

model LandlordVisitUnit {
  id           String        @id @default(uuid())
  visitId      String        @map("visit_id")
  visit        LandlordVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  unitId       String        @map("unit_id")
  unit         Unit          @relation(fields: [unitId], references: [id])
  tenantId     String?       @map("tenant_id")
  tenant       User?         @relation("VisitNotifiedTenant", fields: [tenantId], references: [id])
  notifyTenant Boolean       @default(true) @map("notify_tenant")
  emailSentAt  DateTime?     @map("email_sent_at")

  @@unique([visitId, unitId])
  @@index([visitId])
  @@index([tenantId])
  @@map("landlord_visit_units")
}

model Lease {
  id                   String       @id @default(uuid())
  orgId                String       @map("org_id")
  org                  Organisation @relation(fields: [orgId], references: [id])
  unitId               String       @unique @map("unit_id")
  unit                 Unit         @relation(fields: [unitId], references: [id])
  tenantId             String       @map("tenant_id")
  tenant               User         @relation("TenantLease", fields: [tenantId], references: [id])

  leaseType            LeaseType    @default(UNLIMITED) @map("lease_type")
  startDate            DateTime     @map("start_date")
  endDate              DateTime?    @map("end_date")
  noticePeriodMonths   Int          @default(3) @map("notice_period_months")

  coldRent             Decimal      @db.Decimal(10, 2) @map("cold_rent")
  utilitiesAdvance     Decimal      @db.Decimal(10, 2) @map("utilities_advance")
  totalRent            Decimal      @db.Decimal(10, 2) @map("total_rent")

  depositAmount        Decimal      @db.Decimal(10, 2) @map("deposit_amount")
  depositReceivedDate  DateTime?    @map("deposit_received_date")
  depositReturnedDate  DateTime?    @map("deposit_returned_date")
  depositNotes         String?      @map("deposit_notes")

  status               LeaseStatus  @default(ACTIVE)
  terminatedDate       DateTime?    @map("terminated_date")
  terminationReason    String?      @map("termination_reason") @db.Text

  alert90SentAt        DateTime?    @map("alert_90_sent_at")
  alert60SentAt        DateTime?    @map("alert_60_sent_at")
  alert30SentAt        DateTime?    @map("alert_30_sent_at")

  notes                String?      @db.Text

  documents            Document[]

  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([tenantId])
  @@index([status])
  @@index([endDate])
  @@map("leases")
}

model Document {
  id           String             @id @default(uuid())
  orgId        String             @map("org_id")
  org          Organisation       @relation(fields: [orgId], references: [id])
  uploadedById String             @map("uploaded_by_id")
  uploadedBy   User               @relation("DocumentUploader", fields: [uploadedById], references: [id])

  name         String
  description  String?            @db.Text
  fileUrl      String             @map("file_url")
  fileType     String             @map("file_type")
  fileSizeBytes Int               @map("file_size_bytes")
  category     DocumentCategory
  visibility   DocumentVisibility @default(LANDLORD_ONLY)

  propertyId   String?            @map("property_id")
  property     Property?          @relation(fields: [propertyId], references: [id])
  unitId       String?            @map("unit_id")
  unit         Unit?              @relation(fields: [unitId], references: [id])
  tenantId     String?            @map("tenant_id")
  tenant       User?              @relation("DocumentTenant", fields: [tenantId], references: [id])

  leaseId      String?            @map("lease_id")
  lease        Lease?             @relation(fields: [leaseId], references: [id])

  accessLogs   DocumentAccessLog[]

  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([propertyId])
  @@index([unitId])
  @@index([tenantId])
  @@index([visibility])
  @@map("documents")
}

model DocumentAccessLog {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation("DocumentAccessor", fields: [userId], references: [id])
  accessedAt DateTime @default(now()) @map("accessed_at")

  @@index([documentId])
  @@index([userId])
  @@map("document_access_logs")
}
