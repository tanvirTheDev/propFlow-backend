# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT
JWT_SECRET="your-very-long-random-jwt-secret-here"
JWT_REFRESH_SECRET="your-very-long-random-refresh-secret-here"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="30d"

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"

# Sentry (optional for dev, required for prod)
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Email — nodemailer SMTP (Phase 6)
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_SECURE="false"
MAIL_USER="your@email.com"
MAIL_PASS="your-smtp-password"
MAIL_FROM="noreply@propflow.dev"

# File Upload (Phase 3)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

